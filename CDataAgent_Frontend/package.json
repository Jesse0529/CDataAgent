{
  "name": "aibi-vue-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && vite build",
    "preview": "vite preview",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "echarts": "^6.1.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "naive-ui": "^2.41.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.6.3",
    "vite": "^6.3.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.8"
  }
}
